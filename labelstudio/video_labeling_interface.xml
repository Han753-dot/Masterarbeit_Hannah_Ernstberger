  <Header value="Personenzahl"/>
  <Text name="personen_instruction" value="Bewerte, ob die typische Anzahl gleichzeitig sichtbarer Personen korrekt erfasst wurde."/>
  <Text name="personen_model" value="Modellannotation: $structural_personen_anzahl__personen_anzahl"/>
  <Text name="personen_info" value="Maximale Personenzahl: $structural_personen_anzahl__personen_anzahl_max | Erkannte Frames: $structural_personen_anzahl__detected_person_frames"/>
  <Choices name="eval_personen_anzahl" toName="video" choice="single-radio" required="true">
