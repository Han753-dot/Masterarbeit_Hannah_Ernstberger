  <Text name="aesthetic_instruction" value="Bewerte, ob die Modellinterpretation der ästhetischen Qualität zum Gesamteindruck des Videos passt."/>
  <Text name="aesthetic_model" value="Modellannotation: $aesthetic_quality__score_likert_interpretation"/>
  <Text name="aesthetic_info" value="Aesthetic Quality Score: $aesthetic_quality__aesthetic_quality_score | Scored Frames: $aesthetic_quality__aesthetic_quality_scored_frames"/>
  <Choices name="eval_aesthetic_quality" toName="video" choice="single-radio" required="true">
