<View>
  <Header value="Video Annotation Interface"/>

  <Text name="video_id_meta" value="Video ID: $video_id"/>
  <Text name="source_meta" value="Typ: $influencer_type"/>
  <Text name="influencer_meta" value="Influencer: $influencer"/>
  <Text name="caption_meta" value="Caption: $video_caption"/>

  <Video name="video" value="$local_video_url"/>

  <Header value="Bewertung der Modellannotation"/>
  <Text name="general_instruction" value="Bewerte pro Kategorie, wie gut die angezeigte Modellannotation zum Video passt. 1 = sehr schlecht / klar falsch, 2 = eher schlecht, 3 = teilweise passend, 4 = gut passend, 5 = sehr gut passend. Falls mehrere Ausprägungen im Video vorkommen, beziehe dich auf die Ausprägung, die am längsten sichtbar oder insgesamt dominant ist. Wähle Unbestimmt, wenn die Kategorie nicht sinnvoll beurteilbar ist."/>

  <Header value="Szenerischer Kontext"/>
  <Text name="scene_instruction" value="Bewerte, ob der erkannte dominante Szenenkontext zum Video passt."/>
  <Text name="scene_model" value="Modellannotation: $scene_classification__scene_top1_label"/>
  <Text name="scene_info" value="Confidence: $scene_classification__scene_top1_confidence | Weitere Labels: $scene_classification__scene_unique_labels"/>
  <Choices name="eval_scene_context" toName="video" choice="single-radio" required="true">
    <Choice value="1_sehr_schlecht"/>
    <Choice value="2_eher_schlecht"/>
    <Choice value="3_teilweise_passend"/>
    <Choice value="4_gut_passend"/>
    <Choice value="5_sehr_gut_passend"/>
    <Choice value="Unbestimmt"/>
  </Choices>

  <Header value="Gesichtsorientierung"/>
  <Text name="face_orientation_instruction" value="Bewerte, ob die dominante Gesichts- bzw. Blickrichtung korrekt erfasst wurde."/>
  <Text name="face_orientation_model" value="Modellannotation: $angle_face_orientation__angle_face_orientation"/>
  <Text name="face_orientation_info" value="Pitch: $angle_face_orientation__face_pitch_mean | Yaw: $angle_face_orientation__face_yaw_mean | Face-Frames: $angle_face_orientation__detected_face_frames"/>
  <Choices name="eval_face_orientation" toName="video" choice="single-radio" required="true">
    <Choice value="1_sehr_schlecht"/>
    <Choice value="2_eher_schlecht"/>
    <Choice value="3_teilweise_passend"/>
    <Choice value="4_gut_passend"/>
    <Choice value="5_sehr_gut_passend"/>
    <Choice value="Unbestimmt"/>
  </Choices>

  <Header value="Kameradistanz"/>
  <Text name="camera_distance_instruction" value="Bewerte, ob die dominante Kameradistanz bzw. Einstellungsgröße korrekt erfasst wurde."/>
  <Text name="camera_distance_model" value="Modellannotation: $camera_distance__camera_distance_label"/>
  <Text name="camera_distance_info" value="Confidence: $camera_distance__camera_distance_confidence | Weitere Labels: $camera_distance__camera_distance_unique_labels"/>
  <Choices name="eval_camera_distance" toName="video" choice="single-radio" required="true">
    <Choice value="1_sehr_schlecht"/>
    <Choice value="2_eher_schlecht"/>
    <Choice value="3_teilweise_passend"/>
    <Choice value="4_gut_passend"/>
    <Choice value="5_sehr_gut_passend"/>
    <Choice value="Unbestimmt"/>
  </Choices>

  <Header value="Gesichtsemotion"/>
  <Text name="face_emotion_instruction" value="Bewerte, ob die dominante Gesichtsemotion der sichtbaren Hauptperson korrekt erfasst wurde."/>
  <Text name="face_emotion_model" value="Modellannotation: $face_emotion__emotion_major_beit_readable"/>
  <Text name="face_emotion_info" value="Confidence: $face_emotion__emotion_major_beit_confidence | Weitere Labels: $face_emotion__emotion_unique_labels | Emotion-Frames: $face_emotion__detected_emotion_frames"/>
  <Choices name="eval_face_emotion" toName="video" choice="single-radio" required="true">
    <Choice value="1_sehr_schlecht"/>
    <Choice value="2_eher_schlecht"/>
    <Choice value="3_teilweise_passend"/>
    <Choice value="4_gut_passend"/>
    <Choice value="5_sehr_gut_passend"/>
    <Choice value="Unbestimmt"/>
  </Choices>

  <Header value="Body Pose"/>
  <Text name="body_pose_instruction" value="Bewerte, ob die dominante Körperpose bzw. Pose-Orientierung korrekt erfasst wurde."/>
  <Text name="body_pose_model" value="Modellannotation: $body_pose__pose_orientation"/>
  <Text name="body_pose_info" value="Confidence: $body_pose__pose_confidence | Pose-Frames: $body_pose__detected_pose_frames"/>
  <Choices name="eval_body_pose" toName="video" choice="single-radio" required="true">
    <Choice value="1_sehr_schlecht"/>
    <Choice value="2_eher_schlecht"/>
    <Choice value="3_teilweise_passend"/>
    <Choice value="4_gut_passend"/>
    <Choice value="5_sehr_gut_passend"/>
    <Choice value="Unbestimmt"/>
