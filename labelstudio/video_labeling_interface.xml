  <Text name="brightness_model" value="Modellannotation: $brightness_contrast__brightness_likert_interpretation"/>
  <Text name="brightness_info" value="Brightness Index: $brightness_contrast__brightness_index"/>
  <Choices name="eval_brightness" toName="video" choice="single-radio" required="true">
