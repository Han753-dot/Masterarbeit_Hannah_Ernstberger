  <Header value="Skin Smoothness"/>
  <Text name="skin_instruction" value="Bewerte, ob die Modellinterpretation der Hautglättung bzw. Hauttextur zum sichtbaren Eindruck passt. Falls keine Haut sichtbar ist, wähle Unbestimmt."/>
  <Text name="skin_model" value="Modellannotation: $skin_smoothness__highpass_likert_interpretation"/>
  <Text name="skin_info" value="Highpass Index: $skin_smoothness__skin_smoothness_highpass_index | DoG Index: $skin_smoothness__skin_smoothness_dog_index | DoG Interpretation: $skin_smoothness__dog_likert_interpretation"/>
  <Choices name="eval_skin_smoothness" toName="video" choice="single-radio" required="true">
